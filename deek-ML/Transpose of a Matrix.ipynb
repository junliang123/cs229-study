    "import numpy as np\n",
    "def transpose_matrix(a: list[list[int|float]]) -> list[list[int|float]]:\n",
    "    A = np.array(a)\n",
    "    return A.T\n",
    "print(transpose_matrix([[1, 2], [3, 4], [5, 6]]))"
   ]
  }
